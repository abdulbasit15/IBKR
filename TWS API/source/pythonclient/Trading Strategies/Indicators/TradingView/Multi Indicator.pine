// This Pine Script™ is subject to the terms of the Mozilla Public License 2.0
// © AB
// Includes: EMA1, EMA2, DEMA, RSI+, Supertrend, FVG, VWAP

//@version=5
indicator(title="MultiIndicator by AB", shorttitle="MI-AB", overlay=false, max_boxes_count=500, max_lines_count=500)

// ═══════════════════════════════════════════════════════════════
// TOGGLE INPUTS
// ═══════════════════════════════════════════════════════════════
showEMA1    = input.bool(false, title="Show EMA 1", group="Toggle Indicators")
showEMA2    = input.bool(false, title="Show EMA 2", group="Toggle Indicators")
showDEMA    = input.bool(true, title="Show DEMA", group="Toggle Indicators")
showRSI     = input.bool(true, title="Show RSI+", group="Toggle Indicators")
showST      = input.bool(true, title="Show Supertrend", group="Toggle Indicators")
showFVG     = input.bool(true, title="Show FVG", group="Toggle Indicators")
showVWAP    = input.bool(false, title="Show VWAP", group="Toggle Indicators")

// ═══════════════════════════════════════════════════════════════
// EMA 1 SETTINGS
// ═══════════════════════════════════════════════════════════════
ema1Period = input.int(9, title="EMA 1 Period", minval=1, group="EMA 1")
ema1Color  = input.color(color.orange, title="EMA 1 Color", group="EMA 1")

// ═══════════════════════════════════════════════════════════════
// EMA 2 SETTINGS
// ═══════════════════════════════════════════════════════════════
ema2Period = input.int(21, title="EMA 2 Period", minval=1, group="EMA 2")
ema2Color  = input.color(color.purple, title="EMA 2 Color", group="EMA 2")

// ═══════════════════════════════════════════════════════════════
// DEMA SETTINGS
// ═══════════════════════════════════════════════════════════════
demaPeriod = input.int(200, title="DEMA Period", minval=1, group="DEMA")
demaColor  = input.color(color.blue, title="DEMA Color", group="DEMA")

// ═══════════════════════════════════════════════════════════════
// RSI+ SETTINGS
// ═══════════════════════════════════════════════════════════════
rsiSource       = input.source(close, title="RSI Source", group="RSI+")
rsiPeriod       = input.int(14, title="RSI Period", minval=1, group="RSI+")
rsiMAType       = input.string("EMA", title="MA Type", options=["SMA", "EMA"], group="RSI+")
rsiMALength     = input.int(14, title="RSI MA Length", minval=1, group="RSI+")
rsiOverbought   = input.int(70, title="Overbought Level", group="RSI+")
rsiOversold     = input.int(30, title="Oversold Level", group="RSI+")
rsiUpperBand    = input.int(75, title="Upper Band", group="RSI+")
rsiLowerBand    = input.int(25, title="Lower Band", group="RSI+")
rsiBullColor    = input.color(color.teal, title="Bullish Color", group="RSI+")
rsiBearColor    = input.color(color.red, title="Bearish Color", group="RSI+")
rsiShowBgHighlights = input.bool(true, title="Show Momentum Background", group="RSI+")

// ═══════════════════════════════════════════════════════════════
// SUPERTREND SETTINGS
// ═══════════════════════════════════════════════════════════════
stPeriod      = input.int(10, title="ATR Period", minval=1, group="Supertrend")
stSource      = input.source(hl2, title="Source", group="Supertrend")
stMultiplier  = input.float(3.0, title="ATR Multiplier", step=0.1, group="Supertrend")
stChangeATR   = input.bool(true, title="Change ATR Calculation Method", group="Supertrend")
stShowSignals = input.bool(true, title="Show Buy/Sell Signals", group="Supertrend")
stHighlight   = input.bool(true, title="Highlighter On/Off", group="Supertrend")

// ═══════════════════════════════════════════════════════════════
// FVG (FAIR VALUE GAP) SETTINGS — based on LuxAlgo Fair Value Gap
// ═══════════════════════════════════════════════════════════════
fvgThresholdPer  = input.float(0, "Threshold %", minval=0, maxval=100, step=.1, group="FVG", inline="fvg_threshold")
fvgAuto          = input.bool(false, "Auto", group="FVG", inline="fvg_threshold")
fvgShowLast      = input.int(0, "Unmitigated Levels", minval=0, group="FVG")
fvgMitigationLvl = input.bool(false, "Mitigation Levels", group="FVG")
fvgTf            = input.timeframe("", "Timeframe", group="FVG")
fvgExtend        = input.int(20, "Extend", minval=0, group="FVG", inline="fvg_extend")
fvgDynamic       = input.bool(false, "Dynamic", group="FVG", inline="fvg_extend")
fvgBullCss       = input.color(color.new(#089981, 55), "Bullish FVG", group="FVG")
fvgBearCss       = input.color(color.new(#f23645, 55), "Bearish FVG", group="FVG")
fvgShowDash      = input.bool(false, "Show Dashboard", group="FVG")
fvgDashLoc       = input.string("Top Right", "Dashboard Location", options=["Top Right", "Bottom Right", "Bottom Left"], group="FVG")
fvgTextSize      = input.string("Small", "Dashboard Size", options=["Tiny", "Small", "Normal"], group="FVG")

// ═══════════════════════════════════════════════════════════════
// VWAP SETTINGS
// ═══════════════════════════════════════════════════════════════
vwapSource     = input.source(hlc3, title="VWAP Source", group="VWAP")
vwapAnchor     = input.string("Session", title="Anchor Period", options=["Session", "Week", "Month", "Day"], group="VWAP")
vwapColor      = input.color(color.white, title="VWAP Color", group="VWAP")
vwapShowBands  = input.bool(false, title="Show Std Dev Bands", group="VWAP")
vwapBandMult   = input.float(1.0, title="Band Multiplier", step=0.5, group="VWAP")

// ═══════════════════════════════════════════════════════════════
// EMA 1 CALCULATION
// ═══════════════════════════════════════════════════════════════
ema1Value = ta.ema(close, ema1Period)
plot(showEMA1 ? ema1Value : na, title="EMA 1", color=ema1Color, linewidth=2, force_overlay=true)

// ═══════════════════════════════════════════════════════════════
// EMA 2 CALCULATION
// ═══════════════════════════════════════════════════════════════
ema2Value = ta.ema(close, ema2Period)
plot(showEMA2 ? ema2Value : na, title="EMA 2", color=ema2Color, linewidth=2, force_overlay=true)

// ═══════════════════════════════════════════════════════════════
// DEMA CALCULATION (Double Exponential Moving Average)
// ═══════════════════════════════════════════════════════════════
ema_of_close = ta.ema(close, demaPeriod)
ema_of_ema   = ta.ema(ema_of_close, demaPeriod)
demaValue    = 2 * ema_of_close - ema_of_ema
plot(showDEMA ? demaValue : na, title="DEMA", color=demaColor, linewidth=2, force_overlay=true)

// ═══════════════════════════════════════════════════════════════
// RSI+ CALCULATION
// ═══════════════════════════════════════════════════════════════
rsiValue = ta.rsi(rsiSource, rsiPeriod)
rsiMA    = rsiMAType == "EMA" ? ta.ema(rsiValue, rsiMALength) : ta.sma(rsiValue, rsiMALength)

// RSI+ colors based on RSI vs MA crossover
rsiFillColor = rsiValue >= rsiMA ? color.new(rsiBullColor, 75) : color.new(rsiBearColor, 75)
rsiLineColor = rsiValue >= rsiMA ? rsiBullColor : rsiBearColor
rsiMALineColor = rsiValue >= rsiMA ? color.new(rsiBearColor, 40) : color.new(rsiBullColor, 40)

// RSI+ plots
rsiPlot   = plot(showRSI ? rsiValue : na, title="RSI", color=rsiLineColor, linewidth=2)
rsiMAPlot = plot(showRSI ? rsiMA : na, title="RSI MA", color=rsiMALineColor, linewidth=2)
fill(rsiPlot, rsiMAPlot, title="RSI+ Cloud", color=showRSI ? rsiFillColor : na)

// RSI+ levels
rsiBandOB = hline(rsiOverbought, title="Overbought", color=color.new(color.red, 50), linestyle=hline.style_dashed)
rsiBandOS = hline(rsiOversold, title="Oversold", color=color.new(color.green, 50), linestyle=hline.style_dashed)
rsiBandUpper = hline(rsiUpperBand, title="Upper Band", color=color.new(color.red, 80), linestyle=hline.style_dotted)
rsiBandLower = hline(rsiLowerBand, title="Lower Band", color=color.new(color.green, 80), linestyle=hline.style_dotted)
hline(50, title="Midline", color=color.new(color.gray, 70), linestyle=hline.style_dotted)

// RSI+ Momentum Background Highlights (full-pane vertical coloring)
rsiBgColor = showRSI and rsiShowBgHighlights and rsiValue > rsiOverbought ? color.new(rsiBearColor, 85) : showRSI and rsiShowBgHighlights and rsiValue < rsiOversold ? color.new(rsiBullColor, 85) : na
bgcolor(rsiBgColor, title="Momentum Background")

// RSI+ Cloud Cross Alerts
rsiBullCross = ta.crossover(rsiValue, rsiMA)
rsiBearCross = ta.crossunder(rsiValue, rsiMA)
alertcondition(rsiBullCross, title="RSI+ Bullish Cross", message="RSI+ Bullish: RSI crossed above MA!")
alertcondition(rsiBearCross, title="RSI+ Bearish Cross", message="RSI+ Bearish: RSI crossed below MA!")
alertcondition(rsiBullCross or rsiBearCross, title="RSI+ Cloud Cross", message="RSI+ Cloud Cross detected!")

// ═══════════════════════════════════════════════════════════════
// SUPERTREND CALCULATION
// ═══════════════════════════════════════════════════════════════
stAtr2 = ta.sma(ta.tr, stPeriod)
stAtr  = stChangeATR ? ta.atr(stPeriod) : stAtr2

stUp  = stSource - (stMultiplier * stAtr)
stUp1 = nz(stUp[1], stUp)
stUp  := close[1] > stUp1 ? math.max(stUp, stUp1) : stUp

stDn  = stSource + (stMultiplier * stAtr)
stDn1 = nz(stDn[1], stDn)
stDn  := close[1] < stDn1 ? math.min(stDn, stDn1) : stDn

var int stTrend = 1
stTrend := stTrend == -1 and close > stDn1 ? 1 : stTrend == 1 and close < stUp1 ? -1 : stTrend

stBuySignal  = stTrend == 1 and stTrend[1] == -1
stSellSignal = stTrend == -1 and stTrend[1] == 1

// Supertrend plots (on price chart)
stUpPlot = plot(showST and stTrend == 1 ? stUp : na, title="ST Up Trend", style=plot.style_linebr, linewidth=2, color=color.green, force_overlay=true)
stDnPlot = plot(showST and stTrend == 1 ? na : showST ? stDn : na, title="ST Down Trend", style=plot.style_linebr, linewidth=2, color=color.red, force_overlay=true)

plotshape(showST and stBuySignal ? stUp : na, title="UpTrend Begins", location=location.absolute, style=shape.circle, size=size.tiny, color=color.green, force_overlay=true)
plotshape(showST and stBuySignal and stShowSignals ? stUp : na, title="Buy", text="Buy", location=location.absolute, style=shape.labelup, size=size.tiny, color=color.green, textcolor=color.white, force_overlay=true)
plotshape(showST and stSellSignal ? stDn : na, title="DownTrend Begins", location=location.absolute, style=shape.circle, size=size.tiny, color=color.red, force_overlay=true)
plotshape(showST and stSellSignal and stShowSignals ? stDn : na, title="Sell", text="Sell", location=location.absolute, style=shape.labeldown, size=size.tiny, color=color.red, textcolor=color.white, force_overlay=true)

// Supertrend highlighting
stMidPlot = plot(showST ? ohlc4 : na, title="ST Mid", style=plot.style_circles, linewidth=0, display=display.none, force_overlay=true)
stLongFill  = showST and stHighlight and stTrend == 1 ? color.new(color.green, 90) : color.new(color.white, 100)
stShortFill = showST and stHighlight and stTrend == -1 ? color.new(color.red, 90) : color.new(color.white, 100)
fill(stMidPlot, stUpPlot, title="UpTrend Highlighter", color=stLongFill)
fill(stMidPlot, stDnPlot, title="DownTrend Highlighter", color=stShortFill)

// Supertrend alerts
alertcondition(stBuySignal, title="SuperTrend Buy", message="SuperTrend Buy!")
alertcondition(stSellSignal, title="SuperTrend Sell", message="SuperTrend Sell!")
alertcondition(stTrend != stTrend[1], title="SuperTrend Direction Change", message="SuperTrend has changed direction!")

// ═══════════════════════════════════════════════════════════════
// FVG (FAIR VALUE GAP) CALCULATION — © LuxAlgo (CC BY-NC-SA 4.0)
// ═══════════════════════════════════════════════════════════════
type fvg
    float max
    float min
    bool  isbull
    int   t = time

method tosolid(color id) => color.rgb(color.r(id), color.g(id), color.b(id))

fvgDetect() =>
    var new_fvg = fvg.new(na, na, na, na)
    threshold = fvgAuto ? ta.cum((high - low) / low) / bar_index : fvgThresholdPer / 100

    bull_fvg = low > high[2] and close[1] > high[2] and (low - high[2]) / high[2] > threshold
    bear_fvg = high < low[2] and close[1] < low[2] and (low[2] - high) / high > threshold

    if bull_fvg
        new_fvg := fvg.new(low, high[2], true)
    else if bear_fvg
        new_fvg := fvg.new(low[2], high, false)

    [bull_fvg, bear_fvg, new_fvg]

var float max_bull_fvg = na, var float min_bull_fvg = na, var bull_count = 0, var bull_mitigated = 0
var float max_bear_fvg = na, var float min_bear_fvg = na, var bear_count = 0, var bear_mitigated = 0
var fvgT = 0

var fvg_records = array.new<fvg>(0)
var fvg_areas   = array.new<box>(0)

[bull_fvg, bear_fvg, new_fvg] = request.security(syminfo.tickerid, fvgTf, fvgDetect())

// Bull FVG's
if showFVG and bull_fvg and new_fvg.t != fvgT
    if fvgDynamic
        max_bull_fvg := new_fvg.max
        min_bull_fvg := new_fvg.min
    if not fvgDynamic
        fvg_areas.unshift(box.new(bar_index - 2, new_fvg.max, bar_index + fvgExtend, new_fvg.min, na, bgcolor=fvgBullCss, force_overlay=true))
    fvg_records.unshift(new_fvg)
    bull_count += 1
    fvgT := new_fvg.t
else if showFVG and fvgDynamic
    max_bull_fvg := math.max(math.min(close, max_bull_fvg), min_bull_fvg)

// Bear FVG's
if showFVG and bear_fvg and new_fvg.t != fvgT
    if fvgDynamic
        max_bear_fvg := new_fvg.max
        min_bear_fvg := new_fvg.min
    if not fvgDynamic
        fvg_areas.unshift(box.new(bar_index - 2, new_fvg.max, bar_index + fvgExtend, new_fvg.min, na, bgcolor=fvgBearCss, force_overlay=true))
    fvg_records.unshift(new_fvg)
    bear_count += 1
    fvgT := new_fvg.t
else if showFVG and fvgDynamic
    min_bear_fvg := math.min(math.max(close, min_bear_fvg), max_bear_fvg)

// Test for mitigation
if showFVG and fvg_records.size() > 0
    for i = fvg_records.size() - 1 to 0
        get = fvg_records.get(i)
        if get.isbull
            if close < get.min
                if fvgMitigationLvl
                    line.new(get.t, get.min, time, get.min, xloc.bar_time, color=fvgBullCss, style=line.style_dashed, force_overlay=true)
                if not fvgDynamic
                    area = fvg_areas.remove(i)
                    area.delete()
                fvg_records.remove(i)
                bull_mitigated += 1
        else if close > get.max
            if fvgMitigationLvl
                line.new(get.t, get.max, time, get.max, xloc.bar_time, color=fvgBearCss, style=line.style_dashed, force_overlay=true)
            if not fvgDynamic
                area = fvg_areas.remove(i)
                area.delete()
            fvg_records.remove(i)
            bear_mitigated += 1

// Unmitigated lines
var unmitigated = array.new<line>(0)

if showFVG and barstate.islast and fvgShowLast > 0 and fvg_records.size() > 0
    if unmitigated.size() > 0
        for element in unmitigated
            element.delete()
        unmitigated.clear()
    for i = 0 to math.min(fvgShowLast - 1, fvg_records.size() - 1)
        get = fvg_records.get(i)
        unmitigated.push(line.new(get.t, get.isbull ? get.min : get.max, time, get.isbull ? get.min : get.max, xloc.bar_time, color=get.isbull ? fvgBullCss : fvgBearCss, force_overlay=true))

// Dashboard
var table_position = fvgDashLoc == "Bottom Left" ? position.bottom_left : fvgDashLoc == "Top Right" ? position.top_right : position.bottom_right
var table_size     = fvgTextSize == "Tiny" ? size.tiny : fvgTextSize == "Small" ? size.small : size.normal

var fvgTb = table.new(table_position, 3, 3, bgcolor=#1e222d, border_color=#373a46, border_width=1, frame_color=#373a46, frame_width=1)

if showFVG and fvgShowDash
    if barstate.isfirst
        fvgTb.cell(1, 0, "Bullish", text_color=fvgBullCss.tosolid(), text_size=table_size)
        fvgTb.cell(2, 0, "Bearish", text_color=fvgBearCss.tosolid(), text_size=table_size)
        fvgTb.cell(0, 1, "Count", text_size=table_size, text_color=color.white)
        fvgTb.cell(0, 2, "Mitigated", text_size=table_size, text_color=color.white)
    if barstate.islast
        fvgTb.cell(1, 1, str.tostring(bull_count), text_color=fvgBullCss.tosolid(), text_size=table_size)
        fvgTb.cell(2, 1, str.tostring(bear_count), text_color=fvgBearCss.tosolid(), text_size=table_size)
        fvgTb.cell(1, 2, str.tostring(bull_mitigated / bull_count * 100, format.percent), text_color=fvgBullCss.tosolid(), text_size=table_size)
        fvgTb.cell(2, 2, str.tostring(bear_mitigated / bear_count * 100, format.percent), text_color=fvgBearCss.tosolid(), text_size=table_size)

// Dynamic FVG fills
max_bull_plot = plot(showFVG ? max_bull_fvg : na, color=na, force_overlay=true)
min_bull_plot = plot(showFVG ? min_bull_fvg : na, color=na, force_overlay=true)
fill(max_bull_plot, min_bull_plot, color=showFVG ? fvgBullCss : na)

max_bear_plot = plot(showFVG ? max_bear_fvg : na, color=na, force_overlay=true)
min_bear_plot = plot(showFVG ? min_bear_fvg : na, color=na, force_overlay=true)
fill(max_bear_plot, min_bear_plot, color=showFVG ? fvgBearCss : na)

alertcondition(bull_count > bull_count[1], title="Bullish FVG", message="Bullish FVG detected")
alertcondition(bear_count > bear_count[1], title="Bearish FVG", message="Bearish FVG detected")
alertcondition(bull_mitigated > bull_mitigated[1], title="Bullish FVG Mitigation", message="Bullish FVG mitigated")
alertcondition(bear_mitigated > bear_mitigated[1], title="Bearish FVG Mitigation", message="Bearish FVG mitigated")

// ═══════════════════════════════════════════════════════════════
// VWAP CALCULATION
// ═══════════════════════════════════════════════════════════════
vwapReset = vwapAnchor == "Session" or vwapAnchor == "Day" ? timeframe.change("D") : vwapAnchor == "Week" ? timeframe.change("W") : timeframe.change("M")

var float vwapCumPV  = na
var float vwapCumVol = na
var float vwapCumPV2 = na

if vwapReset or na(vwapCumVol)
    vwapCumPV  := vwapSource * volume
    vwapCumVol := volume
    vwapCumPV2 := vwapSource * vwapSource * volume
else
    vwapCumPV  := vwapCumPV + vwapSource * volume
    vwapCumVol := vwapCumVol + volume
    vwapCumPV2 := vwapCumPV2 + vwapSource * vwapSource * volume

vwapValue = vwapCumPV / vwapCumVol
vwapVar   = vwapCumPV2 / vwapCumVol - vwapValue * vwapValue
vwapDev   = vwapVar > 0 ? math.sqrt(vwapVar) : 0.0

plot(showVWAP ? vwapValue : na, title="VWAP", color=vwapColor, linewidth=2, force_overlay=true)

vwapUpper = plot(showVWAP and vwapShowBands ? vwapValue + vwapBandMult * vwapDev : na, title="VWAP Upper Band", color=color.new(vwapColor, 50), linewidth=1, force_overlay=true)
vwapLower = plot(showVWAP and vwapShowBands ? vwapValue - vwapBandMult * vwapDev : na, title="VWAP Lower Band", color=color.new(vwapColor, 50), linewidth=1, force_overlay=true)
fill(vwapUpper, vwapLower, title="VWAP Bands Fill", color=showVWAP and vwapShowBands ? color.new(vwapColor, 92) : na)
