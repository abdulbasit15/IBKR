type smcAlerts
    bool internalBullishBOS         = false
    bool internalBearishBOS         = false
    bool internalBullishCHoCH       = false
    bool internalBearishCHoCH       = false
    bool swingBullishBOS            = false
    bool swingBearishBOS            = false
    bool swingBullishCHoCH          = false
    bool swingBearishCHoCH          = false
    bool internalBullishOrderBlock  = false
    bool internalBearishOrderBlock  = false
    bool swingBullishOrderBlock     = false
    bool swingBearishOrderBlock     = false
    bool equalHighs                 = false
    bool equalLows                  = false
    bool bullishFairValueGap        = false
    bool bearishFairValueGap        = false

type smcTrailingExtremes
    float top
    float bottom
    int barTime
    int barIndex
    int lastTopTime
    int lastBottomTime

type smcFairValueGap
    float top
    float bottom
    int bias
    box topBox
    box bottomBox

type smcTrend
    int bias

type smcEqualDisplay
    line l_ine      = na
    label l_abel    = na

type smcPivot
    float currentLevel
    float lastLevel
    bool crossed
    int barTime     = time
    int barIndex    = bar_index

type smcOrderBlock
    float barHigh
    float barLow
    int barTime
    int bias

var smcPivot smcSwingHigh                 = smcPivot.new(na, na, false)
var smcPivot smcSwingLow                  = smcPivot.new(na, na, false)
var smcPivot smcInternalHigh              = smcPivot.new(na, na, false)
var smcPivot smcInternalLow               = smcPivot.new(na, na, false)
var smcPivot smcEqualHigh                 = smcPivot.new(na, na, false)
var smcPivot smcEqualLow                  = smcPivot.new(na, na, false)
var smcTrend smcSwingTrend                = smcTrend.new(0)
var smcTrend smcInternalTrend             = smcTrend.new(0)
var smcEqualDisplay smcEqualHighDisplay   = smcEqualDisplay.new()
var smcEqualDisplay smcEqualLowDisplay    = smcEqualDisplay.new()
var array<smcFairValueGap> smcFairValueGaps = array.new<smcFairValueGap>()
var array<float> smcParsedHighs           = array.new<float>()
var array<float> smcParsedLows            = array.new<float>()
var array<float> smcHighs                 = array.new<float>()
var array<float> smcLows                  = array.new<float>()
var array<int> smcTimes                   = array.new<int>()
var smcTrailingExtremes smcTrailing       = smcTrailingExtremes.new()
var array<smcOrderBlock> smcSwingOrderBlocks      = array.new<smcOrderBlock>()
var array<smcOrderBlock> smcInternalOrderBlocks   = array.new<smcOrderBlock>()
var array<box> smcSwingOrderBlocksBoxes             = array.new<box>()
var array<box> smcInternalOrderBlocksBoxes          = array.new<box>()
var color smcSwingBullishColor               = smcStyleInput == SMC_MONOCHROME ? SMC_MONO_BULLISH : smcSwingBullColorInput
var color smcSwingBearishColor               = smcStyleInput == SMC_MONOCHROME ? SMC_MONO_BEARISH : smcSwingBearColorInput
var color smcFairValueGapBullishColor        = smcStyleInput == SMC_MONOCHROME ? color.new(SMC_MONO_BULLISH, 70) : smcFairValueGapsBullColorInput
var color smcFairValueGapBearishColor        = smcStyleInput == SMC_MONOCHROME ? color.new(SMC_MONO_BEARISH, 70) : smcFairValueGapsBearColorInput
var color smcPremiumZoneColor                = smcStyleInput == SMC_MONOCHROME ? SMC_MONO_BEARISH : smcPremiumZoneColorInput
var color smcDiscountZoneColor               = smcStyleInput == SMC_MONOCHROME ? SMC_MONO_BULLISH : smcDiscountZoneColorInput
varip int smcCurrentBarIndex                 = bar_index
varip int smcLastBarIndex                    = bar_index
smcAlerts smcCurrentAlerts                   = smcAlerts.new()
var int smcInitialTime                       = time

// SMC per-bar values (must be declared before functions that reference them)
smcBearishOrderBlockMitigationSource = smcOrderBlockMitigationInput == SMC_CLOSE ? close : high
smcBullishOrderBlockMitigationSource = smcOrderBlockMitigationInput == SMC_CLOSE ? close : low
smcAtrMeasure = ta.atr(200)
smcVolatilityMeasure = smcOrderBlockFilterInput == SMC_ATR ? smcAtrMeasure : ta.cum(ta.tr) / bar_index
smcHighVolatilityBar = (high - low) >= (2 * smcVolatilityMeasure)
smcParsedHigh = smcHighVolatilityBar ? low : high
smcParsedLow = smcHighVolatilityBar ? high : low

smcLeg(int size) =>
    var leg = 0
    newLegHigh = high[size] > ta.highest(high, size)
    newLegLow  = low[size]  < ta.lowest(low, size)
    if newLegHigh
        leg := SMC_BEARISH_LEG
    else if newLegLow
        leg := SMC_BULLISH_LEG
    leg

smcStartOfNewLeg(int leg)     => ta.change(leg) != 0
smcStartOfBearishLeg(int leg) => ta.change(leg) == -1
smcStartOfBullishLeg(int leg) => ta.change(leg) == +1

smcDrawLabel(int labelTime, float labelPrice, string tag, color labelColor, string labelStyle) =>
    var label l_abel = na
    if smcModeInput == SMC_PRESENT
        l_abel.delete()
    l_abel := label.new(chart.point.new(labelTime, na, labelPrice), tag, xloc.bar_time, color=color(na), textcolor=labelColor, style=labelStyle, size=size.small, force_overlay=true)

smcDrawEqualHighLow(smcPivot p_ivot, float level, int size, bool equalHigh) =>
    smcEqualDisplay e_qualDisplay = equalHigh ? smcEqualHighDisplay : smcEqualLowDisplay
    string tag = 'EQL'
    color equalColor = smcSwingBullishColor
    string labelStyle = label.style_label_up
    if equalHigh
        tag := 'EQH'
        equalColor := smcSwingBearishColor
        labelStyle := label.style_label_down
    if smcModeInput == SMC_PRESENT
        line.delete(e_qualDisplay.l_ine)
        label.delete(e_qualDisplay.l_abel)
    e_qualDisplay.l_ine  := line.new(chart.point.new(p_ivot.barTime, na, p_ivot.currentLevel), chart.point.new(time[size], na, level), xloc=xloc.bar_time, color=equalColor, style=line.style_dotted, force_overlay=true)
    labelPosition = math.round(0.5 * (p_ivot.barIndex + bar_index - size))
    e_qualDisplay.l_abel := label.new(chart.point.new(na, labelPosition, level), tag, xloc.bar_index, color=color(na), textcolor=equalColor, style=labelStyle, size=smcEqualHighsLowsSizeInput, force_overlay=true)

smcGetCurrentStructure(int size, bool equalHighLow = false, bool internal = false) =>
    currentLeg = smcLeg(size)
    newPivot = smcStartOfNewLeg(currentLeg)
    pivotLow = smcStartOfBullishLeg(currentLeg)
    pivotHigh = smcStartOfBearishLeg(currentLeg)
    if newPivot
        if pivotLow
            smcPivot p_ivot = equalHighLow ? smcEqualLow : internal ? smcInternalLow : smcSwingLow
            if equalHighLow and math.abs(p_ivot.currentLevel - low[size]) < smcEqualHighsLowsThresholdInput * smcAtrMeasure
                smcDrawEqualHighLow(p_ivot, low[size], size, false)
                smcCurrentAlerts.equalLows := true
            p_ivot.lastLevel := p_ivot.currentLevel
            p_ivot.currentLevel := low[size]
            p_ivot.crossed := false
            p_ivot.barTime := time[size]
            p_ivot.barIndex := bar_index[size]
            if not equalHighLow and not internal
                smcTrailing.bottom := p_ivot.currentLevel
                smcTrailing.barTime := p_ivot.barTime
                smcTrailing.barIndex := p_ivot.barIndex
                smcTrailing.lastBottomTime := p_ivot.barTime
            if smcShowSwingsInput and not internal and not equalHighLow
                smcDrawLabel(time[size], p_ivot.currentLevel, p_ivot.currentLevel < p_ivot.lastLevel ? 'LL' : 'HL', smcSwingBullishColor, label.style_label_up)
        else
            smcPivot p_ivot = equalHighLow ? smcEqualHigh : internal ? smcInternalHigh : smcSwingHigh
            if equalHighLow and math.abs(p_ivot.currentLevel - high[size]) < smcEqualHighsLowsThresholdInput * smcAtrMeasure
                smcDrawEqualHighLow(p_ivot, high[size], size, true)
                smcCurrentAlerts.equalHighs := true
            p_ivot.lastLevel := p_ivot.currentLevel
            p_ivot.currentLevel := high[size]
            p_ivot.crossed := false
            p_ivot.barTime := time[size]
            p_ivot.barIndex := bar_index[size]
            if not equalHighLow and not internal
                smcTrailing.top := p_ivot.currentLevel
                smcTrailing.barTime := p_ivot.barTime
                smcTrailing.barIndex := p_ivot.barIndex
                smcTrailing.lastTopTime := p_ivot.barTime
            if smcShowSwingsInput and not internal and not equalHighLow
                smcDrawLabel(time[size], p_ivot.currentLevel, p_ivot.currentLevel > p_ivot.lastLevel ? 'HH' : 'LH', smcSwingBearishColor, label.style_label_down)

smcDrawStructure(smcPivot p_ivot, string tag, color structureColor, string lineStyle, string labelStyle, string labelSize) =>
    var line l_ine = line.new(na, na, na, na, xloc=xloc.bar_time, force_overlay=true)
    var label l_abel = label.new(na, na, force_overlay=true)
    if smcModeInput == SMC_PRESENT
        l_ine.delete()
        l_abel.delete()
    l_ine  := line.new(chart.point.new(p_ivot.barTime, na, p_ivot.currentLevel), chart.point.new(time, na, p_ivot.currentLevel), xloc.bar_time, color=structureColor, style=lineStyle, force_overlay=true)
    l_abel := label.new(chart.point.new(na, math.round(0.5 * (p_ivot.barIndex + bar_index)), p_ivot.currentLevel), tag, xloc.bar_index, color=color(na), textcolor=structureColor, style=labelStyle, size=labelSize, force_overlay=true)

smcDeleteOrderBlocks(bool internal = false) =>
    array<smcOrderBlock> orderBlocks = internal ? smcInternalOrderBlocks : smcSwingOrderBlocks
    for [index, eachOrderBlock] in orderBlocks
        bool crossedOderBlock = false
        if smcBearishOrderBlockMitigationSource > eachOrderBlock.barHigh and eachOrderBlock.bias == SMC_BEARISH
            crossedOderBlock := true
            if internal
                smcCurrentAlerts.internalBearishOrderBlock := true
            else
                smcCurrentAlerts.swingBearishOrderBlock := true
        else if smcBullishOrderBlockMitigationSource < eachOrderBlock.barLow and eachOrderBlock.bias == SMC_BULLISH
            crossedOderBlock := true
            if internal
                smcCurrentAlerts.internalBullishOrderBlock := true
            else
                smcCurrentAlerts.swingBullishOrderBlock := true
        if crossedOderBlock
            orderBlocks.remove(index)

smcStoreOrderBlock(smcPivot p_ivot, bool internal = false, int bias) =>
    if ((not internal and smcShowSwingOrderBlocksInput) or (internal and smcShowInternalOrderBlocksInput)) and not na(p_ivot.barIndex) and p_ivot.barIndex < bar_index and smcParsedHighs.size() > p_ivot.barIndex
        array<float> a_rray = na
        int localIndex = na
        if bias == SMC_BEARISH
            a_rray := smcParsedHighs.slice(p_ivot.barIndex, bar_index)
            localIndex := a_rray.size() > 0 ? a_rray.indexof(a_rray.max()) : -1
        else
            a_rray := smcParsedLows.slice(p_ivot.barIndex, bar_index)
            localIndex := a_rray.size() > 0 ? a_rray.indexof(a_rray.min()) : -1
        if localIndex >= 0
            int parsedIndex = p_ivot.barIndex + localIndex
            if parsedIndex >= 0 and parsedIndex < smcParsedHighs.size() and parsedIndex < smcParsedLows.size() and parsedIndex < smcTimes.size()
                smcOrderBlock o_rderBlock = smcOrderBlock.new(smcParsedHighs.get(parsedIndex), smcParsedLows.get(parsedIndex), smcTimes.get(parsedIndex), bias)
                array<smcOrderBlock> orderBlocks = internal ? smcInternalOrderBlocks : smcSwingOrderBlocks
                if orderBlocks.size() >= 100
                    orderBlocks.pop()
                orderBlocks.unshift(o_rderBlock)

smcDrawOrderBlocks(bool internal = false) =>
    array<smcOrderBlock> orderBlocks = internal ? smcInternalOrderBlocks : smcSwingOrderBlocks
    orderBlocksSize = orderBlocks.size()
    if orderBlocksSize > 0
        maxOrderBlocks = internal ? smcInternalOrderBlocksSizeInput : smcSwingOrderBlocksSizeInput
        array<smcOrderBlock> parsedOrdeBlocks = orderBlocks.slice(0, math.min(maxOrderBlocks, orderBlocksSize))
        array<box> b_oxes = internal ? smcInternalOrderBlocksBoxes : smcSwingOrderBlocksBoxes
        for [index, eachOrderBlock] in parsedOrdeBlocks
            orderBlockColor = smcStyleInput == SMC_MONOCHROME ? (eachOrderBlock.bias == SMC_BEARISH ? color.new(SMC_MONO_BEARISH, 80) : color.new(SMC_MONO_BULLISH, 80)) : internal ? (eachOrderBlock.bias == SMC_BEARISH ? smcInternalBearishOrderBlockColor : smcInternalBullishOrderBlockColor) : (eachOrderBlock.bias == SMC_BEARISH ? smcSwingBearishOrderBlockColor : smcSwingBullishOrderBlockColor)
            box b_ox = b_oxes.get(index)
            b_ox.set_top_left_point(chart.point.new(eachOrderBlock.barTime, na, eachOrderBlock.barHigh))
            b_ox.set_bottom_right_point(chart.point.new(last_bar_time, na, eachOrderBlock.barLow))
            b_ox.set_border_color(internal ? na : orderBlockColor)
            b_ox.set_bgcolor(orderBlockColor)

smcDisplayStructure(bool internal = false) =>
    var bullishBar = true
    var bearishBar = true
    if smcInternalFilterConfluenceInput
        bullishBar := high - math.max(close, open) > math.min(close, open - low)
        bearishBar := high - math.max(close, open) < math.min(close, open - low)
    smcPivot p_ivot = internal ? smcInternalHigh : smcSwingHigh
    smcTrend t_rend = internal ? smcInternalTrend : smcSwingTrend
    lineStyle = internal ? line.style_dashed : line.style_solid
    labelSize = internal ? smcInternalStructureSize : smcSwingStructureSize
    extraCondition = internal ? smcInternalHigh.currentLevel != smcSwingHigh.currentLevel and bullishBar : true
    bullishColor = smcStyleInput == SMC_MONOCHROME ? SMC_MONO_BULLISH : internal ? smcInternalBullColorInput : smcSwingBullColorInput
    if ta.crossover(close, p_ivot.currentLevel) and not p_ivot.crossed and extraCondition
        string tag = t_rend.bias == SMC_BEARISH ? SMC_CHOCH : SMC_BOS
        if internal
            smcCurrentAlerts.internalBullishCHoCH := tag == SMC_CHOCH
            smcCurrentAlerts.internalBullishBOS := tag == SMC_BOS
        else
            smcCurrentAlerts.swingBullishCHoCH := tag == SMC_CHOCH
            smcCurrentAlerts.swingBullishBOS := tag == SMC_BOS
        p_ivot.crossed := true
        t_rend.bias := SMC_BULLISH
        displayCondition = internal ? smcShowInternalsInput and (smcShowInternalBullInput == SMC_ALL or (smcShowInternalBullInput == SMC_BOS and tag != SMC_CHOCH) or (smcShowInternalBullInput == SMC_CHOCH and tag == SMC_CHOCH)) : smcShowStructureInput and (smcShowSwingBullInput == SMC_ALL or (smcShowSwingBullInput == SMC_BOS and tag != SMC_CHOCH) or (smcShowSwingBullInput == SMC_CHOCH and tag == SMC_CHOCH))
        if displayCondition
            smcDrawStructure(p_ivot, tag, bullishColor, lineStyle, label.style_label_down, labelSize)
        if (internal and smcShowInternalOrderBlocksInput) or (not internal and smcShowSwingOrderBlocksInput)
            smcStoreOrderBlock(p_ivot, internal, SMC_BULLISH)
    p_ivot := internal ? smcInternalLow : smcSwingLow
    extraCondition := internal ? smcInternalLow.currentLevel != smcSwingLow.currentLevel and bearishBar : true
    bearishColor = smcStyleInput == SMC_MONOCHROME ? SMC_MONO_BEARISH : internal ? smcInternalBearColorInput : smcSwingBearColorInput
    if ta.crossunder(close, p_ivot.currentLevel) and not p_ivot.crossed and extraCondition
        string tag = t_rend.bias == SMC_BULLISH ? SMC_CHOCH : SMC_BOS
        if internal
            smcCurrentAlerts.internalBearishCHoCH := tag == SMC_CHOCH
            smcCurrentAlerts.internalBearishBOS := tag == SMC_BOS
        else
            smcCurrentAlerts.swingBearishCHoCH := tag == SMC_CHOCH
            smcCurrentAlerts.swingBearishBOS := tag == SMC_BOS
        p_ivot.crossed := true
        t_rend.bias := SMC_BEARISH
        displayCondition = internal ? smcShowInternalsInput and (smcShowInternalBearInput == SMC_ALL or (smcShowInternalBearInput == SMC_BOS and tag != SMC_CHOCH) or (smcShowInternalBearInput == SMC_CHOCH and tag == SMC_CHOCH)) : smcShowStructureInput and (smcShowSwingBearInput == SMC_ALL or (smcShowSwingBearInput == SMC_BOS and tag != SMC_CHOCH) or (smcShowSwingBearInput == SMC_CHOCH and tag == SMC_CHOCH))
        if displayCondition
            smcDrawStructure(p_ivot, tag, bearishColor, lineStyle, label.style_label_up, labelSize)
        if (internal and smcShowInternalOrderBlocksInput) or (not internal and smcShowSwingOrderBlocksInput)
            smcStoreOrderBlock(p_ivot, internal, SMC_BEARISH)

smcFairValueGapBox(leftTime, rightTime, topPrice, bottomPrice, boxColor) =>
    box.new(chart.point.new(leftTime, na, topPrice), chart.point.new(rightTime + smcFairValueGapsExtendInput * (time - time[1]), na, bottomPrice), xloc=xloc.bar_time, border_color=boxColor, bgcolor=boxColor, force_overlay=true)

smcDeleteFairValueGaps() =>
    for [index, eachFairValueGap] in smcFairValueGaps
        if (low < eachFairValueGap.bottom and eachFairValueGap.bias == SMC_BULLISH) or (high > eachFairValueGap.top and eachFairValueGap.bias == SMC_BEARISH)
            eachFairValueGap.topBox.delete()
            eachFairValueGap.bottomBox.delete()
            smcFairValueGaps.remove(index)

smcDrawFairValueGaps() =>
    [lastClose, lastOpen, lastTime, currentHigh, currentLow, currentTime, last2High, last2Low] = request.security(syminfo.tickerid, smcFairValueGapsTimeframeInput, [close[1], open[1], time[1], high[0], low[0], time[0], high[2], low[2]], lookahead=barmerge.lookahead_on)
    barDeltaPercent = (lastClose - lastOpen) / (lastOpen * 100)
    newTimeframe = timeframe.change(smcFairValueGapsTimeframeInput)
    threshold = smcFairValueGapsThresholdInput ? ta.cum(math.abs(newTimeframe ? barDeltaPercent : 0)) / bar_index * 2 : 0
    bullishFairValueGap = currentLow > last2High and lastClose > last2High and barDeltaPercent > threshold and newTimeframe
    bearishFairValueGap = currentHigh < last2Low and lastClose < last2Low and -barDeltaPercent > threshold and newTimeframe
    if bullishFairValueGap
        smcCurrentAlerts.bullishFairValueGap := true
        smcFairValueGaps.unshift(smcFairValueGap.new(currentLow, last2High, SMC_BULLISH, smcFairValueGapBox(lastTime, currentTime, currentLow, math.avg(currentLow, last2High), smcFairValueGapBullishColor), smcFairValueGapBox(lastTime, currentTime, math.avg(currentLow, last2High), last2High, smcFairValueGapBullishColor)))
    if bearishFairValueGap
        smcCurrentAlerts.bearishFairValueGap := true
        smcFairValueGaps.unshift(smcFairValueGap.new(currentHigh, last2Low, SMC_BEARISH, smcFairValueGapBox(lastTime, currentTime, currentHigh, math.avg(currentHigh, last2Low), smcFairValueGapBearishColor), smcFairValueGapBox(lastTime, currentTime, math.avg(currentHigh, last2Low), last2Low, smcFairValueGapBearishColor)))

smcGetStyle(string style) =>
    switch style
        SMC_SOLID => line.style_solid
        SMC_DASHED => line.style_dashed
        SMC_DOTTED => line.style_dotted

smcDrawLevels(string tf, bool sameTimeframe, string style, color levelColor) =>
    [topLevel, bottomLevel, leftTime, rightTime] = request.security(syminfo.tickerid, tf, [high[1], low[1], time[1], time], lookahead=barmerge.lookahead_on)
    float parsedTop = sameTimeframe ? high : topLevel
    float parsedBottom = sameTimeframe ? low : bottomLevel
    int parsedLeftTime = sameTimeframe ? time : leftTime
    int parsedRightTime = sameTimeframe ? time : rightTime
    int parsedTopTime = time
    int parsedBottomTime = time
    if not sameTimeframe and smcTimes.size() > 0
        int leftIndex = math.max(0, smcTimes.binary_search_rightmost(parsedLeftTime))
        int rightIndex = math.min(smcTimes.size(), math.max(leftIndex, smcTimes.binary_search_rightmost(parsedRightTime)))
        if rightIndex > leftIndex
            array<int> timeArray = smcTimes.slice(leftIndex, rightIndex)
            array<float> topArray = smcHighs.slice(leftIndex, rightIndex)
            array<float> bottomArray = smcLows.slice(leftIndex, rightIndex)
            parsedTopTime := timeArray.size() > 0 ? timeArray.get(topArray.indexof(topArray.max())) : smcInitialTime
            parsedBottomTime := timeArray.size() > 0 ? timeArray.get(bottomArray.indexof(bottomArray.min())) : smcInitialTime
    var line topLine = line.new(na, na, na, na, xloc=xloc.bar_time, color=levelColor, style=smcGetStyle(style), force_overlay=true)
    var line bottomLine = line.new(na, na, na, na, xloc=xloc.bar_time, color=levelColor, style=smcGetStyle(style), force_overlay=true)
    var label topLabel = label.new(na, na, xloc=xloc.bar_time, text=str.format('P{0}H', tf), color=color(na), textcolor=levelColor, size=size.small, style=label.style_label_left, force_overlay=true)
    var label bottomLabel = label.new(na, na, xloc=xloc.bar_time, text=str.format('P{0}L', tf), color=color(na), textcolor=levelColor, size=size.small, style=label.style_label_left, force_overlay=true)
    topLine.set_first_point(chart.point.new(parsedTopTime, na, parsedTop))
    topLine.set_second_point(chart.point.new(last_bar_time + 20 * (time - time[1]), na, parsedTop))
    topLabel.set_point(chart.point.new(last_bar_time + 20 * (time - time[1]), na, parsedTop))
    bottomLine.set_first_point(chart.point.new(parsedBottomTime, na, parsedBottom))
    bottomLine.set_second_point(chart.point.new(last_bar_time + 20 * (time - time[1]), na, parsedBottom))
    bottomLabel.set_point(chart.point.new(last_bar_time + 20 * (time - time[1]), na, parsedBottom))

smcHigherTimeframe(string tf) => timeframe.in_seconds() > timeframe.in_seconds(tf)

smcUpdateTrailingExtremes() =>
    smcTrailing.top := math.max(high, smcTrailing.top)
    smcTrailing.lastTopTime := smcTrailing.top == high ? time : smcTrailing.lastTopTime
    smcTrailing.bottom := math.min(low, smcTrailing.bottom)
    smcTrailing.lastBottomTime := smcTrailing.bottom == low ? time : smcTrailing.lastBottomTime

smcDrawHighLowSwings() =>
    var line topLine = line.new(na, na, na, na, color=smcSwingBearishColor, xloc=xloc.bar_time, force_overlay=true)
    var line bottomLine = line.new(na, na, na, na, color=smcSwingBullishColor, xloc=xloc.bar_time, force_overlay=true)
    var label topLabel = label.new(na, na, color=color(na), textcolor=smcSwingBearishColor, xloc=xloc.bar_time, style=label.style_label_down, size=size.tiny, force_overlay=true)
    var label bottomLabel = label.new(na, na, color=color(na), textcolor=smcSwingBullishColor, xloc=xloc.bar_time, style=label.style_label_up, size=size.tiny, force_overlay=true)
    rightTimeBar = last_bar_time + 20 * (time - time[1])
    topLine.set_first_point(chart.point.new(smcTrailing.lastTopTime, na, smcTrailing.top))
    topLine.set_second_point(chart.point.new(rightTimeBar, na, smcTrailing.top))
    topLabel.set_point(chart.point.new(rightTimeBar, na, smcTrailing.top))
    topLabel.set_text(smcSwingTrend.bias == SMC_BEARISH ? 'Strong High' : 'Weak High')
    bottomLine.set_first_point(chart.point.new(smcTrailing.lastBottomTime, na, smcTrailing.bottom))
    bottomLine.set_second_point(chart.point.new(rightTimeBar, na, smcTrailing.bottom))
    bottomLabel.set_point(chart.point.new(rightTimeBar, na, smcTrailing.bottom))
    bottomLabel.set_text(smcSwingTrend.bias == SMC_BULLISH ? 'Strong Low' : 'Weak Low')

smcDrawZone(float labelLevel, int labelIndex, float top, float bottom, string tag, color zoneColor, string style) =>
    var label l_abel = label.new(na, na, text=tag, color=color(na), textcolor=zoneColor, style=style, size=size.small, force_overlay=true)
    var box b_ox = box.new(na, na, na, na, bgcolor=color.new(zoneColor, 80), border_color=color(na), xloc=xloc.bar_time, force_overlay=true)
    b_ox.set_top_left_point(chart.point.new(smcTrailing.barTime, na, top))
    b_ox.set_bottom_right_point(chart.point.new(last_bar_time, na, bottom))
    l_abel.set_point(chart.point.new(na, labelIndex, labelLevel))

smcDrawPremiumDiscountZones() =>
    smcDrawZone(smcTrailing.top, math.round(0.5 * (smcTrailing.barIndex + last_bar_index)), smcTrailing.top, 0.95 * smcTrailing.top + 0.05 * smcTrailing.bottom, 'Premium', smcPremiumZoneColor, label.style_label_down)
    equilibriumLevel = math.avg(smcTrailing.top, smcTrailing.bottom)
    smcDrawZone(equilibriumLevel, last_bar_index, 0.525 * smcTrailing.top + 0.475 * smcTrailing.bottom, 0.525 * smcTrailing.bottom + 0.475 * smcTrailing.top, 'Equilibrium', smcEquilibriumZoneColorInput, label.style_label_left)
    smcDrawZone(smcTrailing.bottom, math.round(0.5 * (smcTrailing.barIndex + last_bar_index)), 0.95 * smcTrailing.bottom + 0.05 * smcTrailing.top, smcTrailing.bottom, 'Discount', smcDiscountZoneColor, label.style_label_up)

//______________________________________________________________________________
// Elliott Wave Oscillator (EWO) Breaking Bands
// https://www.tradingview.com/script/UcBJKm4O/
//______________________________________________________________________________
src_ewo = get_src(SRC)
ewo1    = ma(type_fast, src_ewo, ma_fast) - ma(type_slow, src_ewo, ma_slow) 
AvgEWO  = ta.ema(ewo1, Len)	

UpperBand = ewo1
UpperBand := nz(UpperBand[1])
if ewo1 > 0
    UpperBand := (UpperBand[1] + 0.0555*(ewo1 - UpperBand[1]))

LowerBand = ewo1
LowerBand := nz(LowerBand[1])
if ewo1 < 0
    LowerBand := (LowerBand[1] + 0.0555*(ewo1 - LowerBand[1]))

red_orange = #FF4000
chartreuse = #80FF00
coral      = #FF8080
lavender   = #8080FF

color_in = ewo1 > LowerBand and ewo1 < 0 ? #824242 : ewo1 > 0 and ewo1 < UpperBand ? #424282 : na
background = ewo1 > 0 ? color.new(#00FFFF, 85) : color.new(#FF0000, 85)  

color_ewo  = ewo1 > UpperBand ? lavender : ewo1  < LowerBand ? coral : color_in
plot(show_EWO ? ewo1 : na, "Elliott Wave Oscillator", color_ewo, 1, plot.style_columns, display=displayPane)

color_sig = AvgEWO > 0 ?  chartreuse : red_orange
plot(show_EWO and signal_ewo ? AvgEWO : na, "Signal(EWO)", color_sig, 2, display=displayPane)

plot(show_EWO and show_bands ? UpperBand : na, "EWO Upper Band", #EFEFBF, display=displayPane)
plot(show_EWO and show_bands ? LowerBand : na, "EWO Lower Band", #EFEFBF, display=displayPane)
// bgcolor disabled on overlay indicator to avoid tinting the price chart

//_________________________________________________________________________________
// Based on "Squeeze Momentum Indicator" - Author:@LazyBear and @J-Streak          
// https://www.tradingview.com/script/nqQ1DT5a-Squeeze-Momentum-Indicator-LazyBear/
// https://www.tradingview.com/script/557GijRq-JS-Squeeze-Pro-2/                   
//_________________________________________________________________________________
// Bollinger Bands Basis Line
basis = ma(bbmatype, src, length) 

// Keltner Channel Basis Line
basiskc = ma(kcmatype, src, length)
// Keltner Channel Range
range_src = useTR ? ta.tr : (high - low)
range_kc  = ma(kcmatype, range_src, length)
// Keltner Channel Low Multiplier
multlowKC = 2.0
// Keltner Channel Mid Multiplier
multmidKC = 1.5
// Keltner Channel High Multiplier
multhighKC = 1.0

// Bollinger Bands 
dev         = multBB * ta.stdev(src, length)
upperBB     = basis + dev
lowerBB     = basis - dev
// Keltner Channel Bands Low 
upperKCl    = basiskc + range_kc * multlowKC
lowerKCl    = basiskc - range_kc * multlowKC
// Keltner Channel Bands Mid
upperKCm    = basiskc + range_kc * multmidKC
lowerKCm    = basiskc - range_kc * multmidKC
// Keltner Channel Bands High
upperKCh    = basiskc + range_kc * multhighKC
lowerKCh    = basiskc - range_kc * multhighKC

//------------------------{ Squeeze Momentum Basics }------------------------------------
// Momentum
ma_momentum = ma(typeMom, srcM, lengthM)
sz = ta.linreg(srcM - math.avg(math.avg(ta.highest(high, lengthM), ta.lowest(low, lengthM)), ma_momentum), lengthM, 0)
sigM = ta.sma(sz, sigLen)
momentum_strength = sz - sigM

// Momentum Conditions
sc1 = sz >= 0
sc2 = sz < 0
sc3 = sz >= sz[1]
sc4 = sz < sz[1]

// Squeeze On
lowsqz      = lowerBB > lowerKCl and upperBB < upperKCl
lsf         = lowsqz == false
midsqz      = lowerBB > lowerKCm and upperBB < upperKCm
msf         = midsqz == false
highsqz     = lowerBB > lowerKCh and upperBB < upperKCh
hsf         = highsqz == false

//-----------------------{ Color Components }-----------------------------------
// Color Conditions
clr1        = sc1 and sc3 ? #00EEFF : 
   sc1 and sc4 ? #000EFF : sc2 and sc4 ? #FF0000 : sc2 and sc3 ? #FFE500 : color.gray
clr2        = sc1 and sc3 ? #00bcd4 : 
   sc1 and sc4 ? #0D47A1 : sc2 and sc4 ? #BA68C8 : sc2 and sc3 ? #9C27B0 : #673AB7
clr3        = sc1 and sc3 ? #15FF00 : sc1 and sc4 ? #335E33 : 
   sc2 and sc4 ? #F44336 : sc2 and sc3 ? #B71C1C : color.gray
clr4        = sc1 and sc3 ? #fff59d : 
   sc1 and sc4 ? #FFD600 : sc2 and sc4 ? #FFCC80 : sc2 and sc3 ? #FF9800 : #702700
clr5        = sc1 and sc3 ? #2196F3 : 
   sc1 and sc4 ? #0D47A1 : sc2 and sc4 ? #EF9A9A : sc2 and sc3 ? #D32F2F : #CE93D8
color_mom   = color_M == 1 ? clr1 : color_M == 2 ? clr2 : 
   color_M == 3 ? clr3 : color_M == 4 ? clr4 : color_M == 5 ? clr5 : na

//-----------------{ Indicator Components and Plots }---------------------------
// Squeeze Dot Colors
orange_red    = #FF4000 // Original Squeeze 
golden_yellow = #FFE500 // High Squeeze
color_sqz = highsqz ? golden_yellow : midsqz ? orange_red : lowsqz ? #2F4F4F : na
// Squeeze Dot Plot Above 
sqzpro = zeroSQZ ? na : highsqz ? highsqz : midsqz ? midsqz : lowsqz ? lowsqz : na
plotshape(show_sqz ? sqzpro : na, "Squeeze Dots", shape.circle, location.top, color_sqz, display=displayPane)

// Momentum Plot
style_mom = StyleMom == "Area" ? plot.style_area : StyleMom == "Columns" ? plot.style_columns : StyleMom == "Histogram" ? plot.style_histogram : plot.style_line
plot(show_Momen ? sz : na, "Momentum", color_mom, 3, style_mom, display=displayPane)
color_strength = momentum_strength > 0 ? #05FFA6 : #FF9900
color_strength_cloud = momentum_strength > 0 ? color.new(#05FFA6, 85) : color.new(#FF9900, 85)
plot(show_strength ? momentum_strength*3 : na, "Momentum Strength", color_strength_cloud, 1, plot.style_columns, display=displayPane)
plot(show_strength ? momentum_strength*3 : na, "Momentum Strength", color_strength, 1, plot.style_line, join = true, display=displayPane)
color_sigM = sz >= sigM ? color.new(#1500FF, 15) : color.new(#FF007A, 15)
plot(showSignal ? sigM : na, "Signal(Momentum)", color_sigM, 2, display=displayPane)

// Plot Zero Line
color_zero =  highsqz ? golden_yellow : midsqz ? orange_red : lowsqz ? color.gray : clr3
plot(zeroSQZ ? 0 : na, "Squeeze Zero Line", color_zero, 2, plot.style_circles, display=displayPane)

// Background Conditions
bg1_dark = color.new(color.gray, 95)
bg2_dark = color.new(#673AB7, 95)
bg3_dark = color.new(color.gray, 95)
bg4_dark = color.new(#FFD600, 95)
bg5_dark = color.new(#CE93D8, 95)

bgc_dark = bgoff ? na : color_M == 1 ? bg1_dark : color_M == 2 ? bg2_dark : 
   color_M == 3 ? bg3_dark : color_M == 4 ? bg4_dark : color_M == 5 ? bg5_dark : na

clr1_bg        = sc1 and sc3 ? color.new(#00EEFF, 80) : 
   sc1 and sc4 ? color.new(#000EFF, 80) : sc2 and sc4 ? color.new(#FF0000, 80) : sc2 and sc3 ? color.new(#FFE500, 80) : color.new(color.gray, 80)
clr2_bg        = sc1 and sc3 ? color.new(#00bcd4, 80) : 
   sc1 and sc4 ? color.new(#0D47A1, 80) : sc2 and sc4 ? color.new(#BA68C8, 80) : sc2 and sc3 ? color.new(#9C27B0, 80) : color.new(#673AB7, 80)
clr3_bg        = sc1 and sc3 ? color.new(#15FF00, 80) : sc1 and sc4 ? color.new(#388E3C, 80) : 
   sc2 and sc4 ? color.new(#F44336, 80) : sc2 and sc3 ? color.new(#B71C1C, 80) : color.new(color.gray, 80)
clr4_bg        = sc1 and sc3 ? color.new(#fff59d, 80) : 
   sc1 and sc4 ? color.new(#FFD600, 80) : sc2 and sc4 ? color.new(#FFCC80, 80) : sc2 and sc3 ? color.new(#FF9800, 80) : color.new(#702700, 80)
clr5_bg        = sc1 and sc3 ? color.new(#2196F3, 80) : 
   sc1 and sc4 ? color.new(#0D47A1, 80) : sc2 and sc4 ? color.new(#EF9A9A, 80) : sc2 and sc3 ? color.new(#D32F2F, 80) : color.new(#CE93D8, 80)
choice_bg      = color_M == 1 ? clr1_bg : color_M == 2 ? clr2_bg : 
   color_M == 3 ? clr3_bg : color_M == 4 ? clr4_bg : color_M == 5 ? clr5_bg : na

// Background trend tint — renders in this script's own pane (respects "Background Off" toggle)
bgcolor(bgc_dark, display=displayPane)

//______________________________________________________________________________
// Based on "Directional Movement Index and ADX"
// https://www.tradingview.com/script/VroqhJmg/
//______________________________________________________________________________
[diplus, diminus, adxValue] = ta.dmi(dilen, adxlen)

biggest(series) =>
    max = 0.0
    max := nz(max[1], series)
    if series > max
        max := series
    max

// Calculate ADX Scale
ni = biggest(sz)
adx_scale = (adxValue - keyLevel + distance) * ni/scale

// J. Welles Wilder, developer of DMI, believed that a DMI reading above 25 indicated a strong trend, 
// while a reading below 20 indicated a weak or non-existent trend.
dmiBull = diplus   >= diminus  and adxValue >= keyLevel
dmiBear = diplus   <  diminus  and adxValue >= keyLevel
dmiWeak = adxValue <  keyLevel and adxValue >  weakTrend

// Colored Directional Movement Index (CDMI) by @dgtrd and modified by @OskarGallard
slope_positive = adxValue > adxValue[1]
diCross = bar_index - ta.valuewhen(ta.cross(diplus, diminus), bar_index, 0)
strong = slope_positive ? "Strong" : " "
weak_up_dn = dmiWeak ? (diplus >= diminus ? "[uptrend]" : "[downtrend]") : ""

dmiColor = dmiBull ? (slope_positive ? #005E1A : color.green) : 
           dmiBear ? (slope_positive ? #800000 : color.red) : 
           dmiWeak ? (slope_positive ? #303943 : #8696A8) : 
           (slope_positive ? #60491B : #FECF49)

txtColor = dmiBull ? (slope_positive ? #D9F5DA : #0B1C0C) : 
           dmiBear ? (slope_positive ? #FFE9E6 : #381814) : 
           dmiWeak ? (slope_positive ? #FFFFFF : #000000) : 
           (slope_positive ? #FEEDB9 : #1D1600)   
 
color_ADX = slope_positive ? pos : neg
plot(show_ADX ? adx_scale : na, "ADX", color_ADX, 2, plot.style_line, join = true, display=displayPane)
plot(zeroSQZ ? na : (show_ADX ? distance* ni/scale : na), "Key Level", keyColor ? dmiColor : color_ADX,  1, plot.style_line, display=displayPane)

// Label
lbStat  = histLabel > 0 ? "\n\n Timeframe: " + timeframe.period + ", " + str.tostring(histLabel) + " bar(s) earlier historical value.-": 
          "\n\n Timeframe: " + timeframe.period + ", last di cross " + str.tostring(diCross) + " bar(s) before.-"

adxMom  = slope_positive ? " ▲ Growing | Previous ADX: " + str.tostring(adxValue[1], "#.##") + ")\n» " : " ▼ Falling | Previous ADX(" + str.tostring(adxValue[1], "#.##") + ")\n» "

diStat  = diplus >= diminus ? "diPlus(" + str.tostring(diplus, "#.##") + ") >= diMinus(" + str.tostring(diminus, "#.##") + ")" :
          "diPlus(" + str.tostring(diplus, "#.##") + ") < diMinus(" + str.tostring(diminus, "#.##") + ")"

dmiText = dmiBull ? strong + " Bullish\n» ADX(" + str.tostring(adxValue, "#.##") + ")" + adxMom + diStat: 
          dmiBear ? strong + " Bearish\n» ADX(" + str.tostring(adxValue, "#.##") + ")" + adxMom + diStat:
          dmiWeak ? "Weak " + weak_up_dn + "\n» ADX(" + str.tostring(adxValue, "#.##") + ")" + adxMom + diStat:
          "No Trend\n» ADX(" + str.tostring(adxValue, "#.##") + ")" + adxMom + diStat

oneDay = 24 * 60 * 60 * 1000
barsAhead = 3
onward = if timeframe.ismonthly
    barsAhead * oneDay * 30
else if timeframe.isweekly
    barsAhead * oneDay * 7
else if timeframe.isdaily
    barsAhead * oneDay
else if timeframe.isminutes
    barsAhead * oneDay * timeframe.multiplier / 1440
else if timeframe.isseconds
    barsAhead * oneDay * timeframe.multiplier / 86400
else
    0

// Colored DMI
plotshape(show_DMI and diplus >= diminus, " +DI > -DI", shape.triangleup,   location.bottom, dmiColor, display=displayPane)
plotshape(show_DMI and diplus <  diminus, " +DI < -DI", shape.triangledown, location.bottom, dmiColor, display=displayPane)

alert_dmiBull = detect_bull_dmi and (dmiBull and dmiBull[1] != dmiBull)
alert_dmiBear = detect_bear_dmi and (dmiBear and dmiBear[1] != dmiBear)

if alert_dmiBull
    alert('Symbol = (' + syminfo.tickerid + ') \n TimeFrame = (' + timeframe.period + ') \n Current Price (' + str.tostring(close) + ') \n Bullish Trend [DMI].', alert.freq_once_per_bar_close)

if alert_dmiBear
    alert('Symbol = (' + syminfo.tickerid + ') \n TimeFrame = (' + timeframe.period + ') \n Current Price (' + str.tostring(close) + ') \n Bearish Trend [DMI].', alert.freq_once_per_bar_close)

// DMI trend-reading label (renders in this script's own pane; y=0 = pane zero line)
if not hideLabel
    label dmiLabel = label.new(time, 0, text="DMI reading: " + dmiText[histLabel] + lbStat
         ,tooltip="                 ◁ how to read colored dmi ▷\n* triangle shapes:\n  ▲- bullish : diplus >= diminus\n  ▼- bearish : diplus < diminus\n* colors:\n  green - bullish trend : adx >= keyLevel and di+ > di-\n  red - bearish trend : adx >= keyLevel and di+ < di- \n  gray - weak trend : weekTrend < adx < keyLevel\n  yellow - no trend : adx < weekTrend\n* color density:\n  darker : adx growing\n  lighter : adx falling "
         ,color=dmiColor[histLabel], xloc=xloc.bar_time, style=label.style_label_left, textcolor = txtColor, textalign=text.align_left)
    label.set_x(dmiLabel, label.get_x(dmiLabel) + onward)
    label.delete(dmiLabel[1])

//_____________________________________________________________________________________
// Hull Moving Average
//_____________________________________________________________________________________
// EHMA    
EHMA(_src, _length) =>  ta.ema((2 * ta.ema(_src, _length / 2)) - ta.ema(_src, _length), math.round(math.sqrt(_length)))
// THMA    
THMA(_src, _length) =>  ta.wma(ta.wma(_src, _length / 3) * 3 - ta.wma(_src, _length / 2) - ta.wma(_src, _length), _length)
// Adaptive HMA 
AHMA(_src, _length) => ta.wma(2 * ta.wma(_src, _length / 2) - ta.wma(_src, _length), math.floor(math.sqrt(_length))) 

// Hull type
hull_type(type, src, len) =>
    type == "HMA"  ? ta.hma(src, len) : type == "EHMA" ? EHMA(src, len) : type == "THMA" ? THMA(src, len/2) : AHMA(src, len)

xHMA = hull_type(h_type, get_src(h_src), h_Length)
longHMA  = ta.crossover(xHMA[0], xHMA[2])
shortHMA = ta.crossunder(xHMA[0], xHMA[2])

hull_color = xHMA[0] > xHMA[2] ? color.new(#45CEA2, 85) : color.new(#CE4571, 85)
plotshape(show_Hull and longHMA,  "Hull - Long Cross",  shape.triangleup,   location.bottom, color.new(#45CEA2, 10), size=size.tiny, text='H', textcolor = #45CEA2, display=displayPane)
plotshape(show_Hull and shortHMA, "Hull - Short Cross", shape.triangledown, location.top,    color.new(#CE4571, 10), size=size.tiny, text='H', textcolor = #CE4571, display=displayPane)

//______________________________________________________________________________
// The Expert Trend Locator - XTL 
//______________________________________________________________________________
media  = ma(MA_Type2, get_src(src_xtl), period_xtl)
cciNT = (get_src(src_xtl) - media) / (0.015 * ta.dev(get_src(src_xtl), period_xtl))
cciT  = (get_src(src_xtl) - media) / (0.015 * ta.dev(math.abs(get_src(src_xtl) - media), period_xtl))
values = uTrad ? cciT : cciNT

var color color_XTL = na
if (values < -fixed_Value) 
    color_XTL := color_xtlDN // Bear
if (-fixed_Value <= values and values <= fixed_Value)
    color_XTL := color_xtlNe // Neutral
if (values > fixed_Value)
    color_XTL := color_xtlUP // Bull
barcolor(candles_XTL ? color_XTL : na, title="XTL - Expert Trend Locator", editable=false) 

//_____________________________________________________________________________________
// Based on "Williams_Vix_Fix_V3_Upper_Text_Plots" - Author: @ChrisMoody
// https://www.tradingview.com/script/1ffumXy5-CM-Williams-Vix-Fix-V3-Upper-Text-Plots/
// https://www.ireallytrade.com/newsletters/VIXFix.pdf
//_____________________________________________________________________________________
// Williams Vix Fix Formula
wvf       = ((ta.highest(close, pd)-low)/(ta.highest(close, pd)))*100
sDev      = mult * ta.stdev(wvf, bbl)
midLine   = ta.sma(wvf, bbl) 
lowerBand = midLine - sDev
upperBand = midLine + sDev
rangeHigh = (ta.highest(wvf, lb)) * ph

// Filtered Criteria
upRange      = low > low[1] and close > high[1]
upRange_Aggr = close > close[1] and close > open[1]
// Filtered Criteria
filtered      = ((wvf[1] >= upperBand[1] or wvf[1] >= rangeHigh[1]) and (wvf < upperBand and wvf < rangeHigh))
filtered_Aggr = (wvf[1] >= upperBand[1] or wvf[1] >= rangeHigh[1]) and not (wvf < upperBand and wvf < rangeHigh)

// Alerts Criteria
alert1  = wvf >= upperBand or wvf >= rangeHigh ? 1 : 0
alert2  = (wvf[1] >= upperBand[1] or wvf[1] >= rangeHigh[1]) and wvf < upperBand and wvf < rangeHigh ? 1 : 0
cond_FE = upRange and close > close[str] and (close < close[ltLB] or close < close[mtLB]) and filtered 
alert3  = cond_FE ? 1 : 0
cond_AE = upRange_Aggr and close > close[str] and (close < close[ltLB] or close < close[mtLB]) and filtered_Aggr
alert4  = cond_AE ? 1 : 0

plotshape(sbcc and  alert1 ? alert1 : na,   "WVF Is True",              shape.triangledown, location.bottom, color.new(#80FF00, 60), size=size.tiny, display=displayPane)
plotshape(sbc  and  alert2 ? alert2 : na,   "WVF Was True - Now False", shape.triangledown, location.bottom, color.new(#008080, 60), size=size.tiny, display=displayPane)
plotshape(sbcAggr and alert4 ? alert4 : na, "WVF Aggressive Entry", shape.triangleup, location.bottom, color.new(#80FF00, 20), size=size.tiny, text='AE', textcolor = #80FF00, display=displayPane)
plotshape(sbcFilt and alert3 ? alert3 : na, "WVF Filtered Entry",   shape.triangleup, location.bottom, color.new(#80FF00, 20), size=size.tiny, text='FE', textcolor = #80FF00, display=displayPane)

if alert_AE and cond_AE
    alert('Symbol = (' + syminfo.tickerid + ') \n TimeFrame = (' + timeframe.period + ') \n Current Price (' + str.tostring(close) + ') \n Aggressive Entry [Williams Vix Fix].', alert.freq_once_per_bar_close)

if alert_FE and cond_FE
    alert('Symbol = (' + syminfo.tickerid + ') \n TimeFrame = (' + timeframe.period + ') \n Current Price (' + str.tostring(close) + ') \n Filtered Entry [Williams Vix Fix].', alert.freq_once_per_bar_close)

//___________________________________________________________________________________________
// Based on "Better Divergence On Any Indicator" - Author: @DoctaBot
// https://www.tradingview.com/script/tbrsp75I-Better-Divergence-On-Any-Indicator-DoctaBot/
//___________________________________________________________________________________________
osc             = show_Momen and drdiv ? sz : show_EWO and diver_EWO ? ewo1 : na
bearColor       = color.new(color.red, 0)
bullColor       = color.new(color.lime, 0)
hiddenBullColor = color.new(#00945F, 15)
hiddenBearColor = color.new(#990040, 15)
textColor       = color.new(color.white, 0)
textColor2      = color.new(#000000, 15)

repaint = (not(delay_plot_til_closed) or barstate.ishistory or barstate.isconfirmed)

plFound = na(ta.pivotlow(osc, lbL, lbR))  ? false : true
phFound = na(ta.pivothigh(osc, lbL, lbR)) ? false : true

_inRange(cond, occurence) =>
	bars = (bar_index - ta.valuewhen(cond, bar_index, occurence))
	rangeLower <= bars and bars <= rangeUpper
	
oscPLCur    = ta.valuewhen(plFound, osc[lbR], 0)                    //Current Oscillator Pivot Low
oscPL1      = ta.valuewhen(plFound, osc[lbR], 1)                    //Last Oscillator Pivot Low
oscPL2      = ta.valuewhen(plFound, osc[lbR], 2)                    //2 Back Oscillator Pivot Low

oscPLCurBar = ta.valuewhen(plFound, bar_index - lbR, 0)             //Current Oscillator Pivot Low Bar Index
oscPL1Bar   = ta.valuewhen(plFound, bar_index - lbR, 1)             //Last Oscillator Pivot Low Bar Index
oscPL2Bar   = ta.valuewhen(plFound, bar_index - lbR, 2)             //2 Back Oscillator Pivot Low Bar Index

oscPHCur    = ta.valuewhen(phFound, osc[lbR], 0)                    //Current Oscillator Pivot High
oscPH1      = ta.valuewhen(phFound, osc[lbR], 1)                    //Last Oscillator Pivot High
oscPH2      = ta.valuewhen(phFound, osc[lbR], 2)                    //2 Back Oscillator Pivot High

oscPHCurBar = ta.valuewhen(phFound, bar_index - lbR, 0)             //Current Oscillator Pivot High Bar Index
oscPH1Bar   = ta.valuewhen(phFound, bar_index - lbR, 1)             //Last Oscillator Pivot High Bar Index
oscPH2Bar   = ta.valuewhen(phFound, bar_index - lbR, 2)             //2 Back Oscillator Pivot High Bar Index

oscPL2Slope = (osc[lbR] - oscPL2)/((bar_index - lbR) - oscPL2Bar)   //Slope Between Pivot Lows
oscPL2Lim   = ((oscPL1Bar - oscPL2Bar)*(oscPL2Slope)) + oscPL2      //Pivot Low Oscillator Intersect Limit

oscPH2Slope = (osc[lbR] - oscPH2)/((bar_index - lbR) - oscPH2Bar)   //Slope Between Pivot Highs
oscPH2Lim   = ((oscPH1Bar - oscPH2Bar)*(oscPH2Slope)) + oscPH2      //Pivot High Oscillator Intersect Limit

// Oscilator Pivots
oscHL1 = (osc[lbR] > oscPL1 and _inRange(plFound, 1))                           //Osc. Higher Low compared to previous
oscHL2 = (osc[lbR] > oscPL2 and _inRange(plFound, 2) and oscPL1 > oscPL2Lim)    //Osc. Higher Low compared to 2 back with no intersection
     
oscLL1 = (osc[lbR] < oscPL1 and _inRange(plFound, 1))                           //Osc. Lower Low compared to previous
oscLL2 = (osc[lbR] < oscPL2 and _inRange(plFound, 2) and oscPL1 > oscPL2Lim)    //Osc. Lower Low compared to 2 back with no intersection
        
oscLH1 = (osc[lbR] < oscPH1 and _inRange(phFound, 1))                           //Osc. Lower High compared to previous
oscLH2 = (osc[lbR] < oscPH2 and _inRange(phFound, 2) and oscPH1 < oscPH2Lim)    //Osc. Lower High compared to 2 back with no intersection
        
oscHH1 = (osc[lbR] > oscPH1 and _inRange(phFound, 1))                           //Osc. Higher High compared to previous
oscHH2 = (osc[lbR] > oscPH2 and _inRange(phFound, 2) and oscPH1 < oscPH2Lim)    //Osc. Higher High compared to 2 back with no intersection

// Price Pivots
priceLL1 = ta.lowest(close, lbR + 2) < ta.valuewhen(plFound, ta.lowest(close, lbR + 2), 1)      //Price Lower Low compared to previous
priceLL2 = ta.lowest(close, lbR + 2) < ta.valuewhen(plFound, ta.lowest(close, lbR + 2), 2)      //Price Lower Low compared to 2 back

priceHL1 = ta.lowest(close, lbR + 2) > ta.valuewhen(plFound, ta.lowest(close, lbR + 2), 1)      //Price Higher Low compared to previous
priceHL2 = ta.lowest(close, lbR + 2) > ta.valuewhen(plFound, ta.lowest(close, lbR + 2), 2)      //Price Higher Low compared to 2 back

priceHH1 = ta.highest(close, lbR + 2) > ta.valuewhen(phFound, ta.highest(close, lbR + 2), 1)    //Price Higher High compared to previous
priceHH2 = ta.highest(close, lbR + 2) > ta.valuewhen(phFound, ta.highest(close, lbR + 2), 2)    //Price Higher High compared to 2 back

priceLH1 = ta.highest(close, lbR + 2) < ta.valuewhen(phFound, ta.highest(close, lbR + 2), 1)    //Price Lower High compared to previous
priceLH2 = ta.highest(close, lbR + 2) < ta.valuewhen(phFound, ta.highest(close, lbR + 2), 2)    //Price Lower High compared to 2 back

// Conditions
bullCond1       = plotBull          and plFound and repaint and (priceLL1 and oscHL1) and osc < 0
bullCond2       = plotBull          and plFound and repaint and (usex2LB ? (priceLL2 and oscHL2) : false) and osc < 0

hiddenBullCond1 = plotHiddenBull    and plFound and repaint and (priceHL1 and oscLL1) and osc < 0
hiddenBullCond2 = plotHiddenBull    and plFound and repaint and (usex2LB ? (priceHL2 and oscLL2) : false) and osc < 0

bearCond1       = plotBear          and phFound and repaint and (priceHH1 and oscLH1) and osc > 0
bearCond2       = plotBear          and phFound and repaint and (usex2LB ? (priceHH2 and oscLH2) : false) and osc > 0

hiddenBearCond1 = plotHiddenBear    and phFound and repaint and (priceLH1 and oscHH1) and osc > 0
hiddenBearCond2 = plotHiddenBear    and phFound and repaint and (usex2LB ? (priceLH2 and oscHH2) : false) and osc > 0

f_drawLine(_x1, _x2, _y1, _y2, _color, _width) =>
    line.new(
     x1     = _x1,
     x2     = _x2,
     y1     = _y1,
     y2     = _y2,
     color  = _color,
     width  = _width,
     xloc   = xloc.bar_index
     )
    
// Plot Bull Lines (line drawing disabled on overlay — use plotshape labels in pane instead)
if false and plFound
    f_drawLine(
     bullCond1 or hiddenBullCond1 ? oscPL1Bar : bullCond2 or hiddenBullCond2 ? oscPL2Bar : oscPLCurBar, 
     oscPLCurBar, 
     bullCond1 or hiddenBullCond1 ? oscPL1 : bullCond2 or hiddenBullCond2 ? oscPL2 : oscPLCur, 
     oscPLCur, 
     bullCond1 or bullCond2 ? bullColor : hiddenBullColor, 
     2)

// Plot Bear Lines (line drawing disabled on overlay — use plotshape labels in pane instead)
if false and phFound
    f_drawLine(
     bearCond1 or hiddenBearCond1 ? oscPH1Bar : bearCond2 or hiddenBearCond2 ? oscPH2Bar : oscPHCurBar, 
     oscPHCurBar, 
     bearCond1 or hiddenBearCond1 ? oscPH1 : bearCond2 or hiddenBearCond2 ? oscPH2 : oscPHCur, 
     oscPHCur, 
     bearCond1 or bearCond2 ? bearColor : hiddenBearColor, 
     2)
     
// Plot Bull Labels
plotshape(
	 bullCond1 or bullCond2 ? osc[lbR] : na,
	 offset=-lbR,
	 title="Regular Bullish Label",
	 text=" R ",
	 style=shape.labelup,
	 location=location.absolute,
	 color=bullColor,
	 textcolor=textColor2,
	 display=displayPane
	 )

// Plot Hidden Bull Labels
plotshape(
	 hiddenBullCond1 or hiddenBullCond2 ? osc[lbR] : na,
	 offset=-lbR,
	 title="Hidden Bullish Label",
	 text=" H ",
	 style=shape.labelup,
	 location=location.absolute,
	 color=hiddenBullColor,
	 textcolor=textColor,
	 display=displayPane
	 )

// Plot Bear Labels
plotshape(
	 bearCond1 or bearCond2 ? osc[lbR] : na,
	 offset=-lbR,
	 title="Regular Bearish Label",
	 text=" R ",
	 style=shape.labeldown,
	 location=location.absolute,
	 color=bearColor,
	 textcolor=textColor,
	 display=displayPane
	 )

// Plot Hidden Bear Labels
plotshape(
	 hiddenBearCond1 or hiddenBearCond2 ? osc[lbR] : na,
	 offset=-lbR,
	 title="Hidden Bearish Label",
	 text=" H ",
	 style=shape.labeldown,
	 location=location.absolute,
	 color=hiddenBearColor,
	 textcolor=textColor,
	 display=displayPane
	 )

// Alerts
if bullCond1 or bullCond2
    alert("Regular Bull Divergence", alert.freq_once_per_bar_close )

if hiddenBullCond1 or hiddenBullCond2
    alert("Hidden Bull Divergence", alert.freq_once_per_bar_close )
    
if bearCond1 or bearCond2
    alert("Regular Bear Divergence", alert.freq_once_per_bar_close )
    
if hiddenBearCond1 or hiddenBearCond2
    alert("Hidden Bear Divergence", alert.freq_once_per_bar_close )
    
alertcondition(bullCond1 or bullCond2,             title = "Regular Bull Divergence", message = "Regular Bull Divergence")
alertcondition(hiddenBullCond1 or hiddenBullCond2, title = "Hidden Bull Divergence",  message = "Hidden Bull Divergence")
alertcondition(bearCond1 or bearCond2,             title = "Regular Bear Divergence", message = "Regular Bear Divergence")
alertcondition(hiddenBearCond1 or hiddenBearCond2, title = "Hidden Bear Divergence",  message = "Hidden Bear Divergence")

//______________________________________________________________________________
// VWAP with Deviation Bands (Price Chart Overlay)
// Note: VWAP only works on intraday timeframes
//______________________________________________________________________________
isIntraday  = timeframe.isintraday
canShowVWAP = show_VWAP and isIntraday

// Reuse pre-calculated cumulative VWAP values from top of script
vwapCalc   = _safeVwap
vwapVar    = _cumVol > 0 ? (_cumHlc3_2Vol / _cumVol) - (vwapCalc * vwapCalc) : 0.0
vwapStdDev = math.sqrt(math.max(vwapVar, 0))
vwapValue  = vwapCalc

// Band levels
vUpper1 = vwapValue + vwapBand1 * vwapStdDev
vLower1 = vwapValue - vwapBand1 * vwapStdDev
vUpper2 = vwapValue + vwapBand2 * vwapStdDev
vLower2 = vwapValue - vwapBand2 * vwapStdDev
vUpper3 = vwapValue + vwapBand3 * vwapStdDev
vLower3 = vwapValue - vwapBand3 * vwapStdDev

// VWAP bands disabled to stay under the 64-plot budget (RE10140).
// The VWAP calculation above is retained because the HP-trade filter uses vwapCalc.

//______________________________________________________________________________
// Relative Volume (RVOL)
//______________________________________________________________________________
avgVol      = ta.sma(volumen, rvolLen)
rvol        = nz(avgVol) > 0 ? volumen / avgVol : 0.0
rvolIsHigh  = rvol >= rvolThresh

// Scale RVOL to fit momentum pane
rvolScaled  = ni != 0 ? (rvol - 1) * ni / rvolScale : 0.0

// RVOL bar colors
rvolColor   = rvolIsHigh ? rvolHighCol : rvolLowCol
plot(show_RVOL ? rvolScaled : na, "RVOL", rvolColor, 1, plot.style_columns, display=displayPane)

// Mark weak squeeze fires (squeeze releases with low volume)
sqzFireBar  = (lowsqz[1] or midsqz[1] or highsqz[1]) and not lowsqz and not midsqz and not highsqz
weakFire    = sqzFireBar and not rvolIsHigh and rvolFilter
plotshape(show_RVOL and weakFire ? 0 : na, "Weak Squeeze Fire", shape.xcross, location.absolute, color.new(#FF5252, 20), size=size.tiny, text="W", textcolor=#FF5252, display=displayPane)

alertcondition(sqzFireBar and rvolIsHigh, title = "Strong Squeeze Fire (RVOL)", message = "Squeeze fired with high relative volume!")
alertcondition(weakFire, title = "Weak Squeeze Fire (Low RVOL)", message = "Squeeze fired but volume is below threshold — potential false signal")

// High-Probability Trade Signal: Squeeze Fire + ADX > KeyLevel + RVOL > Threshold + Price aligned with VWAP
hpLong  = sqzFireBar and sz > 0 and adxValue >= keyLevel and rvolIsHigh and (not isIntraday or close > vwapCalc)
hpShort = sqzFireBar and sz < 0 and adxValue >= keyLevel and rvolIsHigh and (not isIntraday or close < vwapCalc)
hpTrade = hpLong or hpShort

plotshape(show_RVOL and hpLong ? sz : na, "HP Long", shape.arrowup, location.absolute, color.new(#00E676, 0), size=size.small, text="HP", textcolor=#00E676, display=displayPane)
plotshape(show_RVOL and hpShort ? sz : na, "HP Short", shape.arrowdown, location.absolute, color.new(#FF1744, 0), size=size.small, text="HP", textcolor=#FF1744, display=displayPane)

alertcondition(hpLong, title = "High-Probability Long", message = "HP LONG: Squeeze fired + ADX strong + High Volume + Price above VWAP")
alertcondition(hpShort, title = "High-Probability Short", message = "HP SHORT: Squeeze fired + ADX strong + High Volume + Price below VWAP")
alertcondition(hpTrade, title = "High-Probability Trade", message = "High-probability trade signal detected — all confluence filters passed")

//______________________________________________________________________________
// Smart Money Concepts — price-chart overlay
//______________________________________________________________________________
if show_SMC and barstate.isfirst
    if smcShowSwingOrderBlocksInput
        for index = 1 to smcSwingOrderBlocksSizeInput
            smcSwingOrderBlocksBoxes.push(box.new(na, na, na, na, xloc=xloc.bar_time, extend=extend.right, force_overlay=true))
    if smcShowInternalOrderBlocksInput
        for index = 1 to smcInternalOrderBlocksSizeInput
            smcInternalOrderBlocksBoxes.push(box.new(na, na, na, na, xloc=xloc.bar_time, extend=extend.right, force_overlay=true))

if show_SMC
    smcParsedHighs.push(smcParsedHigh)
    smcParsedLows.push(smcParsedLow)
    smcHighs.push(high)
    smcLows.push(low)
    smcTimes.push(time)

    if smcShowHighLowSwingsInput or smcShowPremiumDiscountZonesInput
        smcUpdateTrailingExtremes()
        if smcShowHighLowSwingsInput
            smcDrawHighLowSwings()
        if smcShowPremiumDiscountZonesInput
            smcDrawPremiumDiscountZones()

    if smcShowFairValueGapsInput
        smcDeleteFairValueGaps()

    smcGetCurrentStructure(smcSwingsLengthInput, false)
    smcGetCurrentStructure(5, false, true)

    if smcShowEqualHighsLowsInput
        smcGetCurrentStructure(smcEqualHighsLowsLengthInput, true)

    if smcShowInternalsInput or smcShowInternalOrderBlocksInput or smcShowTrendInput
        smcDisplayStructure(true)

    if smcShowStructureInput or smcShowSwingOrderBlocksInput or smcShowHighLowSwingsInput
        smcDisplayStructure()

    if smcShowInternalOrderBlocksInput
        smcDeleteOrderBlocks(true)

    if smcShowSwingOrderBlocksInput
        smcDeleteOrderBlocks()

    if smcShowFairValueGapsInput
        smcDrawFairValueGaps()

    if barstate.islastconfirmedhistory or barstate.islast
        if smcShowInternalOrderBlocksInput
            smcDrawOrderBlocks(true)
        if smcShowSwingOrderBlocksInput
            smcDrawOrderBlocks()

    smcLastBarIndex := smcCurrentBarIndex
    smcCurrentBarIndex := bar_index
    smcNewBar = smcCurrentBarIndex != smcLastBarIndex

    if barstate.islastconfirmedhistory or (barstate.isrealtime and smcNewBar)
        if smcShowDailyLevelsInput and not smcHigherTimeframe('D')
            smcDrawLevels('D', timeframe.isdaily, smcDailyLevelsStyleInput, smcDailyLevelsColorInput)
        if smcShowWeeklyLevelsInput and not smcHigherTimeframe('W')
            smcDrawLevels('W', timeframe.isweekly, smcWeeklyLevelsStyleInput, smcWeeklyLevelsColorInput)
        if smcShowMonthlyLevelsInput and not smcHigherTimeframe('M')
            smcDrawLevels('M', timeframe.ismonthly, smcMonthlyLevelsStyleInput, smcMonthlyLevelsColorInput)

// SMC alerts use alert() instead of alertcondition() to stay under the 64-plot budget.
// These fire via the "Any alert() function call" option when creating an alert.
if show_SMC
    if smcCurrentAlerts.internalBullishBOS
        alert('SMC Internal Bullish BOS formed', alert.freq_once_per_bar_close)
    if smcCurrentAlerts.internalBullishCHoCH
        alert('SMC Internal Bullish CHoCH formed', alert.freq_once_per_bar_close)
    if smcCurrentAlerts.internalBearishBOS
        alert('SMC Internal Bearish BOS formed', alert.freq_once_per_bar_close)
    if smcCurrentAlerts.internalBearishCHoCH
        alert('SMC Internal Bearish CHoCH formed', alert.freq_once_per_bar_close)
    if smcCurrentAlerts.swingBullishBOS
        alert('SMC Bullish BOS formed', alert.freq_once_per_bar_close)
    if smcCurrentAlerts.swingBullishCHoCH
        alert('SMC Bullish CHoCH formed', alert.freq_once_per_bar_close)
    if smcCurrentAlerts.swingBearishBOS
        alert('SMC Bearish BOS formed', alert.freq_once_per_bar_close)
    if smcCurrentAlerts.swingBearishCHoCH
        alert('SMC Bearish CHoCH formed', alert.freq_once_per_bar_close)
    if smcCurrentAlerts.internalBullishOrderBlock
        alert('SMC Price broke bullish internal OB', alert.freq_once_per_bar_close)
    if smcCurrentAlerts.internalBearishOrderBlock
        alert('SMC Price broke bearish internal OB', alert.freq_once_per_bar_close)
    if smcCurrentAlerts.swingBullishOrderBlock
        alert('SMC Price broke bullish swing OB', alert.freq_once_per_bar_close)
    if smcCurrentAlerts.swingBearishOrderBlock
        alert('SMC Price broke bearish swing OB', alert.freq_once_per_bar_close)
    if smcCurrentAlerts.equalHighs
        alert('SMC Equal highs detected', alert.freq_once_per_bar_close)
    if smcCurrentAlerts.equalLows
        alert('SMC Equal lows detected', alert.freq_once_per_bar_close)
    if smcCurrentAlerts.bullishFairValueGap
        alert('SMC Bullish FVG formed', alert.freq_once_per_bar_close)
    if smcCurrentAlerts.bearishFairValueGap
        alert('SMC Bearish FVG formed', alert.freq_once_per_bar_close)

smcTrendCandleColor = show_SMC and smcShowTrendInput ? (smcInternalTrend.bias == SMC_BULLISH ? smcSwingBullishColor : smcSwingBearishColor) : na
plotcandle(show_SMC and smcShowTrendInput ? open : na, high, low, close, color=smcTrendCandleColor, wickcolor=smcTrendCandleColor, bordercolor=smcTrendCandleColor, force_overlay=true) 